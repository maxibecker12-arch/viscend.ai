<script>
// ── CALCULATOR ──────────────────────────────────────────
function fmt(n) {
  return Math.round(n).toLocaleString('de-DE') + ' €';
}

function updateCalc() {
  const leads  = +document.getElementById('slider-leads').value;
  const missed = +document.getElementById('slider-missed').value;
  const close  = +document.getElementById('slider-close').value;
  const val    = +document.getElementById('slider-value').value;

  document.getElementById('val-leads').textContent = leads;
  document.getElementById('val-missed').textContent = missed + ' %';
  document.getElementById('val-close').textContent  = close  + ' %';
  document.getElementById('val-value').textContent  = val.toLocaleString('de-DE') + ' €';

  const monthly = leads * (missed / 100) * (close / 100) * val;
  const yearly  = monthly * 12;

  document.getElementById('result-monthly').textContent = fmt(monthly);
  document.getElementById('result-yearly').textContent  = fmt(yearly);
  document.getElementById('warn-amount').textContent    = fmt(monthly);

  // Update slider track fill
  updateSliderFill('slider-leads',  leads,   0, 100);
  updateSliderFill('slider-missed', missed,  0, 100);
  updateSliderFill('slider-close',  close,   0, 100);
  updateSliderFill('slider-value',  val,     0, 30000);
}

function updateSliderFill(id, val, min, max) {
  const pct = ((val - min) / (max - min)) * 100;
  const el = document.getElementById(id);
  el.style.setProperty('--progress', pct + '%');
  // For WebKit track color
  el.style.background = `linear-gradient(to right, #4FC3F7 0%, #4FC3F7 ${pct}%, rgba(79,195,247,0.15) ${pct}%)`;
}

// Init
updateCalc();

// ── SCROLL ANIMATIONS ────────────────────────────────────
const observer = new IntersectionObserver((entries) => {
  entries.forEach(entry => {
    if (entry.isIntersecting) {
      entry.target.classList.add('visible');
    }
  });
}, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });

document.querySelectorAll('.fade-in').forEach(el => observer.observe(el));

// ── SMOOTH ANCHOR SCROLL ──────────────────────────────────
document.querySelectorAll('a[href^="#"]').forEach(a => {
  a.addEventListener('click', e => {
    const target = document.querySelector(a.getAttribute('href'));
    if (target) {
      e.preventDefault();
      target.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }
  });
});
</script>

