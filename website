<!DOCTYPE html>

<html lang="de">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>VISCEND AI – Speed-to-Lead & Pipeline Recovery System</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&family=Manrope:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
–bg-deep: #020810;
–bg-dark: #050A15;
–ice-blue: #4FC3F7;
–ice-blue-2: #81D4FA;
–ice-cyan: #00E5FF;
–glow-blue: rgba(79, 195, 247, 0.4);
–glow-cyan: rgba(0, 229, 255, 0.3);
–text-white: #FFFFFF;
–text-gray: #8B9AB0;
–text-light: #C5D0DC;
–glass-bg: rgba(255,255,255,0.04);
–glass-border: rgba(79,195,247,0.15);
–glass-border-strong: rgba(79,195,247,0.3);
–red-warn: #FF4444;
–red-glow: rgba(255, 68, 68, 0.5);
}

html { scroll-behavior: smooth; }

body {
background: var(–bg-deep);
color: var(–text-white);
font-family: ‘Manrope’, sans-serif;
line-height: 1.6;
overflow-x: hidden;
}

/* BACKGROUND EFFECTS */
.bg-canvas {
position: fixed;
inset: 0;
z-index: 0;
pointer-events: none;
}
.bg-orb {
position: absolute;
border-radius: 50%;
filter: blur(120px);
opacity: 0.12;
}
.bg-orb-1 { width: 600px; height: 600px; top: -200px; left: 50%; transform: translateX(-50%); background: radial-gradient(circle, #4FC3F7, #1565C0); }
.bg-orb-2 { width: 400px; height: 400px; bottom: 20%; right: -100px; background: radial-gradient(circle, #00E5FF, #0D47A1); }
.bg-orb-3 { width: 350px; height: 350px; top: 60%; left: -80px; background: radial-gradient(circle, #4FC3F7, #1A237E); }

/* NOISE TEXTURE OVERLAY */
.bg-canvas::after {
content: ‘’;
position: absolute;
inset: 0;
background-image: url(“data:image/svg+xml,%3Csvg viewBox=‘0 0 256 256’ xmlns=‘http://www.w3.org/2000/svg’%3E%3Cfilter id=‘noise’%3E%3CfeTurbulence type=‘fractalNoise’ baseFrequency=‘0.9’ numOctaves=‘4’ stitchTiles=‘stitch’/%3E%3C/filter%3E%3Crect width=‘100%25’ height=‘100%25’ filter=‘url(%23noise)’ opacity=‘0.03’/%3E%3C/svg%3E”);
opacity: 0.4;
}

/* LAYOUT */
.container { max-width: 1100px; margin: 0 auto; padding: 0 24px; position: relative; z-index: 1; }

/* NAV */
nav {
position: fixed; top: 0; left: 0; right: 0; z-index: 100;
padding: 16px 24px;
background: rgba(2, 8, 16, 0.7);
backdrop-filter: blur(20px);
border-bottom: 1px solid rgba(79,195,247,0.08);
}
.nav-inner {
max-width: 1100px; margin: 0 auto;
display: flex; align-items: center; justify-content: space-between;
}
.nav-logo {
font-family: ‘Outfit’, sans-serif;
font-weight: 800; font-size: 18px;
letter-spacing: 2px;
background: linear-gradient(135deg, #fff 0%, var(–ice-blue) 100%);
-webkit-background-clip: text; -webkit-text-fill-color: transparent;
}
.nav-cta {
background: linear-gradient(135deg, #1E88E5, var(–ice-cyan));
color: #000; font-weight: 700; font-size: 13px;
padding: 10px 20px; border-radius: 50px; border: none;
cursor: pointer; letter-spacing: 0.5px;
box-shadow: 0 0 20px rgba(79,195,247,0.4);
transition: all 0.3s ease;
text-decoration: none; display: inline-block;
}
.nav-cta:hover { box-shadow: 0 0 35px rgba(79,195,247,0.7); transform: translateY(-1px); }

/* SECTIONS */
section { position: relative; z-index: 1; }

/* HERO */
.hero {
min-height: 100vh;
display: flex; flex-direction: column; align-items: center; justify-content: center;
text-align: center;
padding: 120px 24px 80px;
}
.hero-logo-wrap {
position: relative;
width: 140px; height: 140px;
margin: 0 auto 48px;
}
.hero-logo-wrap::before {
content: ‘’;
position: absolute;
inset: -30px;
background: radial-gradient(circle, rgba(79,195,247,0.25) 0%, transparent 70%);
border-radius: 50%;
animation: logoPulse 3s ease-in-out infinite;
}
.hero-logo-wrap::after {
content: ‘’;
position: absolute;
inset: -60px;
background: radial-gradient(circle, rgba(0,229,255,0.08) 0%, transparent 70%);
border-radius: 50%;
animation: logoPulse 3s ease-in-out infinite 1s;
}
@keyframes logoPulse {
0%, 100% { opacity: 0.6; transform: scale(1); }
50% { opacity: 1; transform: scale(1.05); }
}
.hero-logo-img {
width: 140px; height: 140px;
object-fit: contain;
position: relative; z-index: 2;
filter: drop-shadow(0 0 30px rgba(79,195,247,0.6));
}

/* SVG Logo Fallback */
.logo-svg {
width: 140px; height: 140px;
position: relative; z-index: 2;
}

.hero h1 {
font-family: ‘Outfit’, sans-serif;
font-size: clamp(26px, 5vw, 52px);
font-weight: 800;
line-height: 1.18;
max-width: 820px;
margin: 0 auto 28px;
letter-spacing: -0.5px;
}
.hero h1 .highlight-red { color: #FF5252; text-shadow: 0 0 20px rgba(255,82,82,0.5); }
.hero h1 .highlight-blue { color: var(–ice-blue); text-shadow: 0 0 20px var(–glow-blue); }

.hero-sub {
font-size: clamp(15px, 2.5vw, 19px);
color: var(–text-light);
max-width: 680px;
margin: 0 auto 44px;
line-height: 1.7;
font-weight: 400;
}
.hero-sub strong { color: var(–ice-blue); font-weight: 700; }

.btn-primary {
display: inline-flex; align-items: center; gap: 10px;
background: linear-gradient(135deg, #1976D2 0%, var(–ice-cyan) 100%);
color: #000; font-weight: 800; font-size: 15px;
padding: 18px 40px; border-radius: 60px; border: none;
cursor: pointer; letter-spacing: 0.3px;
box-shadow: 0 0 40px rgba(79,195,247,0.5), 0 4px 30px rgba(0,0,0,0.4);
transition: all 0.3s ease; text-decoration: none;
font-family: ‘Outfit’, sans-serif;
position: relative; overflow: hidden;
}
.btn-primary::before {
content: ‘’;
position: absolute; inset: 0;
background: linear-gradient(135deg, rgba(255,255,255,0.2), transparent);
opacity: 0; transition: opacity 0.3s;
}
.btn-primary:hover { box-shadow: 0 0 60px rgba(79,195,247,0.75), 0 8px 40px rgba(0,0,0,0.5); transform: translateY(-3px); }
.btn-primary:hover::before { opacity: 1; }

.btn-arrow { font-size: 18px; }

.hero-social-proof {
margin-top: 32px;
font-size: 13px; color: var(–text-gray);
display: flex; align-items: center; gap: 8px; justify-content: center;
}
.proof-dot { width: 6px; height: 6px; border-radius: 50%; background: var(–ice-blue); display: inline-block; }

/* SECTION HEADERS */
.section-label {
font-size: 11px; font-weight: 700; letter-spacing: 3px;
color: var(–ice-blue); text-transform: uppercase;
margin-bottom: 16px;
}
.section-title {
font-family: ‘Outfit’, sans-serif;
font-size: clamp(24px, 4vw, 42px);
font-weight: 800; line-height: 1.2;
margin-bottom: 20px;
letter-spacing: -0.3px;
}

/* GLASS CARD */
.glass-card {
background: var(–glass-bg);
border: 1px solid var(–glass-border);
border-radius: 24px;
backdrop-filter: blur(20px);
-webkit-backdrop-filter: blur(20px);
padding: 40px;
position: relative;
overflow: hidden;
transition: border-color 0.3s, transform 0.3s;
}
.glass-card::before {
content: ‘’;
position: absolute; top: 0; left: 0; right: 0;
height: 1px;
background: linear-gradient(90deg, transparent, rgba(79,195,247,0.4), transparent);
}
.glass-card:hover {
border-color: var(–glass-border-strong);
transform: translateY(-4px);
}

/* PROBLEM SECTION */
.problem-section { padding: 100px 0; }
.problem-section .section-title { text-align: center; margin-bottom: 16px; }
.problem-section .section-label { text-align: center; }
.problem-section .section-subtitle { text-align: center; color: var(–text-gray); margin-bottom: 60px; font-size: 17px; }

.cards-grid {
display: grid;
grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
gap: 24px;
}

.problem-card { text-align: center; }
.card-icon {
width: 64px; height: 64px;
background: linear-gradient(135deg, rgba(79,195,247,0.1), rgba(0,229,255,0.05));
border: 1px solid var(–glass-border);
border-radius: 18px;
display: flex; align-items: center; justify-content: center;
margin: 0 auto 24px;
font-size: 28px;
}
.problem-card h3 {
font-family: ‘Outfit’, sans-serif;
font-size: 18px; font-weight: 700;
margin-bottom: 14px;
color: var(–ice-blue-2);
}
.problem-card p { color: var(–text-light); font-size: 15px; line-height: 1.7; }

/* SOLUTION SECTION */
.solution-section { padding: 100px 0; }
.solution-inner {
display: grid;
grid-template-columns: 1fr 1fr;
gap: 60px;
align-items: center;
}
.solution-text .section-title { text-align: left; }
.solution-text .section-label { text-align: left; }

.feature-item {
display: flex; gap: 18px; align-items: flex-start;
margin-bottom: 36px;
}
.feature-num {
flex-shrink: 0;
width: 44px; height: 44px;
background: linear-gradient(135deg, #1976D2, var(–ice-cyan));
border-radius: 12px;
display: flex; align-items: center; justify-content: center;
font-family: ‘Outfit’, sans-serif;
font-weight: 800; font-size: 16px; color: #000;
}
.feature-content h4 {
font-family: ‘Outfit’, sans-serif;
font-weight: 700; font-size: 17px;
margin-bottom: 8px; color: var(–ice-blue-2);
}
.feature-content p { color: var(–text-light); font-size: 15px; line-height: 1.65; }

/* PHONE MOCKUP */
.phone-mockup-wrap {
display: flex; justify-content: center; align-items: center;
}
.phone-mockup {
width: 240px;
background: rgba(255,255,255,0.06);
border: 1px solid rgba(79,195,247,0.2);
border-radius: 40px;
padding: 20px 16px;
backdrop-filter: blur(30px);
box-shadow: 0 0 60px rgba(79,195,247,0.15), 0 30px 80px rgba(0,0,0,0.5), inset 0 1px 0 rgba(255,255,255,0.1);
position: relative;
animation: phoneFloat 4s ease-in-out infinite;
}
@keyframes phoneFloat {
0%, 100% { transform: translateY(0px) rotate(-2deg); }
50% { transform: translateY(-12px) rotate(-2deg); }
}
.phone-notch {
width: 60px; height: 8px;
background: rgba(255,255,255,0.1); border-radius: 4px;
margin: 0 auto 16px;
}
.sms-bubble {
background: rgba(30, 136, 229, 0.15);
border: 1px solid rgba(79,195,247,0.25);
border-radius: 16px 16px 16px 4px;
padding: 12px 14px;
margin-bottom: 12px;
}
.sms-header { font-size: 10px; color: var(–ice-blue); font-weight: 700; margin-bottom: 6px; letter-spacing: 0.5px; }
.sms-text { font-size: 12px; color: var(–text-light); line-height: 1.5; }
.sms-link {
display: inline-block; margin-top: 8px;
font-size: 11px; color: var(–ice-cyan); font-weight: 700;
text-decoration: underline;
}
.sms-time { font-size: 10px; color: var(–text-gray); text-align: right; margin-top: 4px; }
.sms-status {
background: rgba(0,229,255,0.08);
border: 1px solid rgba(0,229,255,0.15);
border-radius: 10px;
padding: 8px 12px;
display: flex; align-items: center; gap: 8px;
margin-top: 8px;
}
.status-dot { width: 8px; height: 8px; border-radius: 50%; background: #00E676; flex-shrink: 0; box-shadow: 0 0 8px #00E676; }
.status-text { font-size: 11px; color: var(–text-light); }

/* CALCULATOR SECTION */
.calc-section { padding: 100px 0; }
.calc-section .section-title { text-align: center; }
.calc-section .section-label { text-align: center; }
.calc-subtitle { text-align: center; color: var(–text-gray); font-size: 17px; margin-bottom: 60px; max-width: 560px; margin-left: auto; margin-right: auto; }

.calc-card {
background: rgba(5,10,21,0.8);
border: 1px solid var(–glass-border);
border-radius: 32px;
padding: clamp(28px, 5vw, 56px);
backdrop-filter: blur(30px);
box-shadow: 0 0 80px rgba(79,195,247,0.08);
position: relative; overflow: hidden;
}
.calc-card::before {
content: ‘’;
position: absolute; top: 0; left: 0; right: 0; height: 1px;
background: linear-gradient(90deg, transparent, rgba(79,195,247,0.5), transparent);
}

.calc-grid {
display: grid;
grid-template-columns: 1fr 1fr;
gap: 40px 60px;
margin-bottom: 48px;
}

.slider-group label {
display: flex; justify-content: space-between; align-items: baseline;
font-size: 14px; font-weight: 600; color: var(–text-light);
margin-bottom: 14px;
}
.slider-val {
font-family: ‘Outfit’, sans-serif;
font-size: 20px; font-weight: 800;
background: linear-gradient(135deg, var(–ice-blue), var(–ice-cyan));
-webkit-background-clip: text; -webkit-text-fill-color: transparent;
}

input[type=“range”] {
-webkit-appearance: none; appearance: none;
width: 100%; height: 4px;
background: rgba(79,195,247,0.15);
border-radius: 2px; outline: none;
cursor: pointer;
}
input[type=“range”]::-webkit-slider-runnable-track {
height: 4px;
background: linear-gradient(to right, var(–ice-blue) 0%, var(–ice-blue) var(–progress, 25%), rgba(79,195,247,0.15) var(–progress, 25%));
border-radius: 2px;
}
input[type=“range”]::-moz-range-track {
height: 4px; background: rgba(79,195,247,0.15); border-radius: 2px;
}
input[type=“range”]::-moz-range-progress {
height: 4px; background: var(–ice-blue); border-radius: 2px;
}
input[type=“range”]::-webkit-slider-thumb {
-webkit-appearance: none; appearance: none;
width: 22px; height: 22px;
background: linear-gradient(135deg, var(–ice-blue), var(–ice-cyan));
border-radius: 50%;
border: 3px solid #050A15;
box-shadow: 0 0 14px rgba(79,195,247,0.7);
cursor: pointer; margin-top: -9px;
transition: box-shadow 0.2s;
}
input[type=“range”]::-webkit-slider-thumb:hover {
box-shadow: 0 0 22px rgba(79,195,247,1);
}
input[type=“range”]::-moz-range-thumb {
width: 22px; height: 22px;
background: linear-gradient(135deg, var(–ice-blue), var(–ice-cyan));
border-radius: 50%; border: 3px solid #050A15;
box-shadow: 0 0 14px rgba(79,195,247,0.7); cursor: pointer;
}

.calc-divider { border: none; border-top: 1px solid rgba(79,195,247,0.1); margin: 8px 0 40px; }

.result-box {
text-align: center;
background: rgba(255,68,68,0.04);
border: 1px solid rgba(255,68,68,0.15);
border-radius: 24px;
padding: 40px;
margin-bottom: 32px;
}
.result-label { font-size: 14px; font-weight: 600; color: var(–text-gray); letter-spacing: 1px; text-transform: uppercase; margin-bottom: 16px; }
.result-number {
font-family: ‘Outfit’, sans-serif;
font-size: clamp(42px, 8vw, 72px);
font-weight: 900;
color: #FF5252;
text-shadow: 0 0 40px rgba(255,82,82,0.6);
line-height: 1;
margin-bottom: 12px;
letter-spacing: -2px;
}
.result-year { font-size: 16px; color: var(–text-gray); font-weight: 500; }
.result-year strong { color: #FF7070; font-weight: 700; }

.calc-warning {
text-align: center;
background: rgba(79,195,247,0.04);
border: 1px solid var(–glass-border);
border-radius: 16px;
padding: 20px 28px;
color: var(–text-light);
font-size: 15px; line-height: 1.6;
margin-bottom: 32px;
}
.calc-warning strong { color: var(–ice-blue); }

.calc-cta-wrap { text-align: center; }
.btn-secondary {
display: inline-flex; align-items: center; gap: 10px;
background: transparent;
border: 1.5px solid var(–ice-blue);
color: var(–ice-blue);
font-weight: 700; font-size: 15px;
padding: 16px 36px; border-radius: 60px;
cursor: pointer; letter-spacing: 0.3px;
transition: all 0.3s ease;
font-family: ‘Outfit’, sans-serif;
text-decoration: none;
box-shadow: 0 0 20px rgba(79,195,247,0.1), inset 0 0 20px rgba(79,195,247,0.03);
}
.btn-secondary:hover {
background: rgba(79,195,247,0.08);
box-shadow: 0 0 40px rgba(79,195,247,0.3);
transform: translateY(-2px);
}

/* GUARANTEE SECTION */
.guarantee-section { padding: 100px 0; }
.guarantee-card {
max-width: 800px; margin: 0 auto;
text-align: center;
background: linear-gradient(135deg, rgba(21,101,192,0.08), rgba(0,229,255,0.04));
border: 1px solid rgba(79,195,247,0.2);
border-radius: 32px;
padding: clamp(40px, 6vw, 72px) clamp(28px, 5vw, 80px);
box-shadow: 0 0 80px rgba(79,195,247,0.1);
position: relative; overflow: hidden;
}
.guarantee-card::before {
content: ‘’;
position: absolute; top: 0; left: 0; right: 0; height: 1px;
background: linear-gradient(90deg, transparent, var(–ice-blue), transparent);
}
.guarantee-badge {
display: inline-flex; align-items: center; gap: 10px;
background: rgba(79,195,247,0.1);
border: 1px solid var(–glass-border);
border-radius: 30px;
padding: 8px 20px;
font-size: 12px; font-weight: 700; letter-spacing: 1.5px;
color: var(–ice-blue); text-transform: uppercase;
margin-bottom: 28px;
}
.guarantee-card .section-title { font-size: clamp(22px, 4vw, 36px); margin-bottom: 24px; }
.guarantee-card p { color: var(–text-light); font-size: clamp(15px, 2vw, 17px); line-height: 1.8; max-width: 600px; margin: 0 auto; }

/* FINAL CTA SECTION */
.final-cta-section { padding: 100px 0 120px; }
.final-cta-inner { text-align: center; max-width: 700px; margin: 0 auto; }
.final-cta-inner .section-title { font-size: clamp(26px, 4.5vw, 48px); margin-bottom: 20px; }
.final-cta-inner p { color: var(–text-light); font-size: clamp(15px, 2vw, 18px); line-height: 1.7; margin-bottom: 48px; }

.calendly-embed {
background: var(–glass-bg);
border: 1px solid var(–glass-border);
border-radius: 24px;
padding: 48px;
text-align: center;
color: var(–text-gray);
font-size: 15px;
min-height: 200px;
display: flex; align-items: center; justify-content: center;
flex-direction: column; gap: 16px;
}
.calendly-placeholder-icon { font-size: 40px; opacity: 0.5; }
.calendly-placeholder-text { max-width: 300px; line-height: 1.6; }

/* FOOTER */
footer {
border-top: 1px solid rgba(79,195,247,0.08);
padding: 32px 24px;
text-align: center;
color: var(–text-gray);
font-size: 13px;
position: relative; z-index: 1;
}
footer .footer-brand {
font-family: ‘Outfit’, sans-serif;
font-weight: 800; font-size: 15px; letter-spacing: 2px;
background: linear-gradient(135deg, #fff, var(–ice-blue));
-webkit-background-clip: text; -webkit-text-fill-color: transparent;
margin-bottom: 8px;
}

/* SCROLL ANIMATIONS */
.fade-in {
opacity: 0;
transform: translateY(30px);
transition: opacity 0.7s ease, transform 0.7s ease;
}
.fade-in.visible {
opacity: 1;
transform: translateY(0);
}
.fade-in-delay-1 { transition-delay: 0.1s; }
.fade-in-delay-2 { transition-delay: 0.2s; }
.fade-in-delay-3 { transition-delay: 0.3s; }

/* SECTION SPACING */
.section-header { margin-bottom: 60px; }
.section-header.center { text-align: center; }

/* RESPONSIVE */
@media (max-width: 768px) {
.solution-inner { grid-template-columns: 1fr; }
.phone-mockup-wrap { order: -1; }
.calc-grid { grid-template-columns: 1fr; gap: 28px; }
.glass-card { padding: 28px; }
nav { padding: 12px 16px; }
.hero { padding: 100px 20px 60px; }
.hero-logo-wrap { width: 100px; height: 100px; }
.hero-logo-img, .logo-svg { width: 100px; height: 100px; }
.cards-grid { grid-template-columns: 1fr; }
.btn-primary { font-size: 14px; padding: 16px 28px; }
.result-box { padding: 28px 20px; }
.calc-card { padding: 24px; }
.guarantee-card { padding: 40px 24px; }
}

@media (max-width: 480px) {
.nav-logo { font-size: 15px; }
.nav-cta { font-size: 12px; padding: 8px 16px; }
.solution-inner { gap: 40px; }
}

/* SEPARATOR LINE */
.sep {
height: 1px;
background: linear-gradient(90deg, transparent, rgba(79,195,247,0.2), transparent);
margin: 0 24px;
}

/* Glow line decoration */
.glow-line {
width: 80px; height: 2px;
background: linear-gradient(90deg, var(–ice-blue), var(–ice-cyan));
border-radius: 1px;
box-shadow: 0 0 12px var(–glow-blue);
margin: 0 auto 32px;
}
.glow-line.left { margin-left: 0; }
</style>

</head>
<body>

<!-- Background -->

<div class="bg-canvas">
  <div class="bg-orb bg-orb-1"></div>
  <div class="bg-orb bg-orb-2"></div>
  <div class="bg-orb bg-orb-3"></div>
</div>

<!-- NAV -->

<nav>
  <div class="nav-inner">
    <div class="nav-logo">VISCEND AI</div>
    <a href="#demo" class="nav-cta">Live-Demo buchen</a>
  </div>
</nav>

<!-- ═══════════════ HERO ═══════════════ -->

<section class="hero">
  <div class="hero-logo-wrap fade-in">
    <!-- Inline SVG logo replicating the VISCEND AI aesthetic -->
    <svg class="logo-svg" viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg" style="filter: drop-shadow(0 0 30px rgba(79,195,247,0.6));">
